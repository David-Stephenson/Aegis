AUTH_SECRET=replace-with-a-long-random-secret
AUTH_AUTHENTIK_ISSUER=https://auth.example.com/application/o/aegis/
AUTH_AUTHENTIK_CLIENT_ID=aegis
AUTH_AUTHENTIK_CLIENT_SECRET=replace-me

CADDY_API_BASE_URL=http://127.0.0.1:2019
CADDY_API_TOKEN=replace-me

# Comma-separated list of trusted proxy CIDRs. Leave empty if no reverse proxy in front.
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128

# Where local SQLite state is stored.
DB_PATH=data/aegis.db

# Group to service mapping from Authentik groups.
# Example: {"admin":["grafana","argocd"],"dev":["grafana"]}
GROUP_SERVICE_MAP_JSON={"admin":["grafana"],"dev":["grafana"]}

# Service definitions with exact Caddy admin API config paths for remote_ip arrays.
# Example path: /config/apps/http/servers/srv0/routes/0/match/0/remote_ip
SERVICE_DEFINITIONS_JSON=[{"id":"grafana","name":"Grafana","description":"Internal dashboards","allowlistConfigPath":"/config/apps/http/servers/srv0/routes/0/match/0/remote_ip"}]
